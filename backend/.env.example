PORT=5000
NODE_ENV=development

# PostgreSQL — use DATABASE_URL for production (e.g. Digital Ocean), individual vars for local
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grayphite
DB_USER=postgres
DB_PASSWORD=your_password
DB_SCHEMA=banking

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:5173
